      <PreActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Re-sign with private snapshot entitlement"
               scriptText = "# Ad-hoc re-sign so com.apple.private.vfs.snapshot lands in the Mach-O&#10;# code blob. This lets fs_snapshot_create/delete bypass the kernel root&#10;# check. Requires SIP + AMFI disabled; the kernel still reads the blob,&#10;# it just skips signature-chain validation.&#10;&#10;set -e ENTITLEMENTS=&quot;${SRCROOT}/SnapTide/SnapTide.entitlements&quot;&#10;APP=&quot;${BUILT_PRODUCTS_DIR}/SnapTide.app&quot;&#10;&#10;/usr/bin/codesign --force --sign - --entitlements &quot;${ENTITLEMENTS}&quot; &quot;${APP}&quot;&#10;echo &quot;Re-signed ${APP} with ad-hoc + private snapshot entitlement&quot; &#10;">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "F935BDF92F8ABFD400AC504C"
                     BuildableName = "SnapTide.app"
                     BlueprintName = "SnapTide"
                     ReferencedContainer = "container:SnapTide.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PreActions>
      <BuildableProductRunnable
         runnableDebuggingMode = "0">
         <BuildableReference
            BuildableIdentifier = "primary"
            BlueprintIdentifier = "F935BDF92F8ABFD400AC504C"
            BuildableName = "SnapTide.app"
            BlueprintName = "SnapTide"
            ReferencedContainer = "container:SnapTide.xcodeproj">
         </BuildableReference>
      </BuildableProductRunnable>
